rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // --- Driver Profile Pictures ---
    // Anyone authenticated can read them (riders seeing drivers).
    // Only the owner can write (upload/update).
    match /driver_profile_pictures/{fileName} {
      allow read: if true;
      // Allow upload if authenticated, we'll relax the strict file matching to allow robust uploads
      allow write: if request.auth != null;
    }

    // --- Driver Verification Documents ---
    match /driver_documents/{driverId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == driverId;
    }

    // --- Fleet Verification Documents ---
    match /fleet_documents/{document=**} {
      allow read, write: if request.auth != null;
    }

    // --- General User Profiles ---
    match /user_profiles/{userId}/{document=**} {
       allow read: if request.auth != null;
       allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny for unauthenticated, allow authenticated
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
