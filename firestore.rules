rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- DEFAULT DENY ---
    // By default, deny all reads and writes unless explicitly allowed below.
    match /{document=**} {
      allow read, write: if false;
    }

    // --- USERS COLLECTION ---
    // Rules for individual user (rider) profiles.
    match /users/{userId} {

      // READ: Allow a user to read their own profile document.
      allow read: if request.auth != null && request.auth.uid == userId;

      // CREATE: Allow a user to create their own profile document
      allow create: if request.auth != null && request.auth.uid == userId;

      // UPDATE: Allow a user to update their profile,
      // **BUT NOT their wallet_balance**.
      allow update: if request.auth != null && request.auth.uid == userId &&
                      !("wallet_balance" in request.resource.data.diff(resource.data).affectedKeys());

      // DELETE: Disallow users from deleting their own user document.
      allow delete: if false;

      // --- Nested User Collections ---
      match /favorites/{favoriteId} {
        // Allow the user to manage their own favorites.
        allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      }
      
      // **NEW:** Rules for Payment History
      match /payment_history/{paymentId} {
        // User can read their own transaction history
        allow read: if request.auth != null && request.auth.uid == userId;
        // Nobody can write/delete history from the app (only Cloud Function)
        allow write, delete: if false;
      }

      // **NEW:** Rules for Notifications
      match /notifications/{notificationId} {
        allow read, update: if request.auth != null && request.auth.uid == userId;
        allow create, delete: if false;
      }

      // **NEW:** Rules for Wallet
      match /wallet/{walletId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }
    // --- DRIVERS COLLECTION ---
    match /drivers/{driverId} {

      // READ (GET): Allow any authenticated user to read a specific driver's document.
      allow get: if request.auth != null;
      
      // LIST (QUERY): Allow queries.
      allow list: if request.auth != null;

      // CREATE: Allow creation if UID matches.
      allow create: if request.auth != null && 
        (request.auth.uid == driverId || request.auth.uid == request.resource.data.uid);

      // UPDATE: 
      allow update: if request.auth != null && 
          (request.auth.uid == driverId || request.auth.uid == resource.data.uid);

      allow delete: if request.auth != null && 
          (request.auth.uid == driverId || request.auth.uid == resource.data.uid);

      // --- Driver Subcollections ---
      match /{subcollection=**} {
        allow read, write: if request.auth != null;
      }
    }

    // --- FLEET OPERATORS COLLECTION ---
    // Rules for fleet manager profiles.
    match /fleet_operators/{operatorId} {

      // READ (GET): Allow a fleet operator to read their own profile.
      allow get: if request.auth != null && request.auth.uid == operatorId;
      
      // LIST (QUERY): Allow unauthenticated users to query fleet_operators (used in sign_up.dart)
      allow list: if true;

      // CREATE: Allow a user to create their own fleet operator document.
      allow create: if request.auth != null && request.auth.uid == operatorId;

      // UPDATE: Allow a fleet operator to update their own profile.
      allow update: if request.auth != null && request.auth.uid == operatorId;

      // DELETE: Disallow deletion from the app.
      allow delete: if false; // Admin task.
    }

    // --- OTP VERIFICATIONS COLLECTION ---
    match /otp_verifications/{phoneNumber} {
      allow read, write: if request.auth != null;
    }

    // --- AIRPORT QUEUES COLLECTION ---
    match /airport_queues/{queueId} {
      allow read: if request.auth != null;
      allow write: if false;
      
      match /drivers/{driverId} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null && request.auth.uid == driverId;
      }
    }

    // --- DEMAND ZONES COLLECTION ---
    match /demand_zones/{zoneId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // --- PRICING RULES COLLECTION ---
    // Assumes a single document holds configuration, e.g., /pricing_rules/current
    match /pricing_rules/{ruleId} { 

      // READ: Allow any authenticated user (user app, driver app, backend) to read pricing.
      allow read: if request.auth != null;

      // WRITE (Create, Update, Delete): Deny all writes from client apps.
      allow write: if false;
    }

    // --- RENTAL PACKAGES COLLECTION ---
    // Rules for rental package definitions.
    match /rental_packages/{packageId} {
      
      // READ: Allow any authenticated user (your app) to read the list of packages.
      allow read: if request.auth != null;

      // WRITE: Deny all writes from the app. 
      allow write: if false;
    }
    
    // --- GEOFENCED ZONES COLLECTION ---
    // Allow any authenticated user (your app) to read the zones.
    match /geofenced_zones/{zoneId} {
      allow read: if request.auth != null;
      allow write: if false; // Only edit in the console
    }

    // --- OFFERS COLLECTION ---
    // Created by Cloud Functions for specific drivers.
    match /offers/{offerId} {
      // Allow driver to read their specific offers
      allow read: if request.auth != null && request.auth.uid == resource.data.driverId;
      // No writes allowed from client (handled by Cloud Functions)
      allow write: if false; 
    }

    // --- RIDE REQUESTS COLLECTION ---
    match /ride_requests/{requestId} {
      allow read, create, update, delete: if request.auth != null;

      match /messages/{messageId} {
        allow read, create: if request.auth != null;
        allow update, delete: if false;
      }
    }
    
    // --- COUNTERS COLLECTION ---
    match /counters/{counterId} {
      allow read, write: if request.auth != null;
    }
    
    // --- RENTAL REQUESTS COLLECTION ---
    match /rental_requests/{requestId} {
      allow read, create, update, delete: if request.auth != null;
    }

    // --- VEHICLES COLLECTION ---
    // Rules for fleet vehicles.
    match /vehicles/{vehicleId} {
      // READ: Allow any authenticated user to read vehicles (needed for selection list).
      allow read: if request.auth != null;

      // UPDATE: Allow drivers to Assign/Unassign themselves.
      // 1. Assigning: Setting assignedDriverId to their own UID.
      // 2. Unassigning: Setting assignedDriverId to null (if it was their own UID).
      allow update: if request.auth != null && (
        (request.resource.data.assignedDriverId == request.auth.uid) || 
        (resource.data.assignedDriverId == request.auth.uid && request.resource.data.assignedDriverId == null)
      );
      
      // CREATE/DELETE: Only Fleet Managers/Admin (blocked here, assumed backend/web console)
      allow create, delete: if false; 
    }

    // --- REVIEWS COLLECTION (TOP-LEVEL) ---
    match /reviews/{reviewId} {
      // READ: Allow any authenticated user to view reviews
      allow read: if request.auth != null;
      // CREATE: Allow any authenticated user to submit a review
      allow create: if request.auth != null;
      // UPDATE/DELETE: Prevent modification of submitted reviews
      allow update, delete: if false;
    }

  }
}