rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if the caller is the driver who owns a driver document.
    // driverId in the path is the professional ID (e.g. indi-drv-4), NOT the auth UID.
    // The driver doc stores the auth UID in the 'uid' field.
    function isDriverOwner(driverId) {
      return isSignedIn() && (
        request.auth.uid == driverId ||
        resource.data.get('uid', '') == request.auth.uid
      );
    }

    // Checks if the caller is the driver who owns a driver document, using get().
    // Used for subcollections where 'resource' is the subcollection doc, not the parent.
    function isDriverOwnerByGet(driverId) {
      return isSignedIn() && (
        request.auth.uid == driverId ||
        get(/databases/$(database)/documents/drivers/$(driverId)).data.get('uid', '') == request.auth.uid
      );
    }

    // --- DEFAULT DENY ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;

      match /{subcollection=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- DRIVERS COLLECTION ---
    match /drivers/{driverId} {
      // Any signed-in user can read driver profiles (for ride tracking, ratings)
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      // Create: UID-based docs only (professional ID docs created by Cloud Functions)
      allow create: if isOwner(driverId);
      // Update: allow if auth UID matches doc ID (legacy) OR the 'uid' field in the doc
      allow update: if isDriverOwner(driverId);
      allow delete: if false;

      // Subcollections: only the owning driver can access
      match /{subcollection=**} {
        allow read, write: if isDriverOwnerByGet(driverId);
      }
    }

    // --- OTP VERIFICATIONS ---
    match /otp_verifications/{phoneNumber} {
      allow read, write: if false; // Cloud Functions only
    }

    // --- RIDE REQUESTS ---
    match /ride_requests/{rideId} {
      // GET: users read their own ride, drivers read their assigned ride
      allow get: if isSignedIn() &&
                    (request.auth.uid == resource.data.userId ||
                     request.auth.uid == resource.data.driverUid);

      // LIST: only when querying with driverUid == auth.uid OR userId == auth.uid
      // This ensures the security rule is provably satisfied for all query results.
      allow list: if isSignedIn() &&
                    (request.auth.uid == resource.data.userId ||
                     request.auth.uid == resource.data.driverUid);

      // Users create rides
      allow create: if isOwner(request.resource.data.userId);

      // Users and assigned drivers can update
      allow update: if isSignedIn() &&
                      (request.auth.uid == resource.data.userId ||
                       request.auth.uid == resource.data.driverUid);

      allow delete: if false;

      match /messages/{messageId} {
        allow read, create: if isSignedIn() &&
          (request.auth.uid == get(/databases/$(database)/documents/ride_requests/$(rideId)).data.userId ||
           request.auth.uid == get(/databases/$(database)/documents/ride_requests/$(rideId)).data.driverUid);
        allow update, delete: if false;
      }
    }

    // --- FLEET OPERATORS ---
    match /fleet_operators/{operatorId} {
      allow get: if isOwner(operatorId);
      allow list: if isSignedIn();
      allow create: if isOwner(operatorId);
      allow update: if isOwner(operatorId);
      allow delete: if false;
    }

    // --- EARNINGS (READ ONLY) ---
    match /earnings/{earningId} {
      allow read: if isSignedIn() && (
        resource.data.driverUid == request.auth.uid ||
        resource.data.driverId == request.auth.uid
      );
      allow write: if false; // Cloud Functions only
    }

    // --- WALLET TRANSACTIONS (READ ONLY) ---
    match /wallet_transactions/{txId} {
      allow read: if isSignedIn();
      allow write: if false; // Cloud Functions only
    }

    // --- PRICING RULES (READ ONLY) ---
    match /pricing_rules/{ruleId} {
      allow read: if isSignedIn();
      allow write: if false; // Admin only
    }

    // --- RENTAL PACKAGES (READ ONLY) ---
    match /rental_packages/{packageId} {
      allow read: if isSignedIn();
      allow write: if false; // Admin only
    }

    // --- GEOFENCED ZONES (READ ONLY) ---
    match /geofenced_zones/{zoneId} {
      allow read: if isSignedIn();
      allow write: if false; // Admin only
    }

    // --- AIRPORT QUEUES ---
    match /airport_queues/{queueId} {
      allow read: if isSignedIn();
      allow write: if false; // Cloud Functions only

      match /drivers/{driverId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isDriverOwnerByGet(driverId);
      }
    }

    // --- DEMAND ZONES (READ ONLY) ---
    match /demand_zones/{zoneId} {
      allow read: if isSignedIn();
      allow write: if false; // Admin only
    }

    // --- REVIEWS (READ + CREATE) ---
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // --- VEHICLES ---
    match /vehicles/{vehicleId} {
      allow read: if isSignedIn();
      allow update: if isSignedIn() &&
        (request.resource.data.assignedDriverId == request.auth.uid ||
         (resource.data.assignedDriverId == request.auth.uid &&
          request.resource.data.assignedDriverId == null));
      allow create, delete: if false;
    }

    // --- RENTAL REQUESTS ---
    match /rental_requests/{rideId} {
      // GET: users or assigned driver only
      allow get: if isSignedIn() &&
                    (request.auth.uid == resource.data.userId ||
                     request.auth.uid == resource.data.driverUid);

      // LIST: allow any signed-in user to browse available rentals.
      // Drivers need to see all status=='searching' rentals to find jobs nearby.
      allow list: if isSignedIn();

      allow create: if isOwner(request.resource.data.userId);
      allow update: if isSignedIn() &&
                      (request.auth.uid == resource.data.userId ||
                       request.auth.uid == resource.data.driverUid);
      allow delete: if false;
    }

    // --- COUNTERS ---
    match /counters/{counterId} {
      allow read: if isSignedIn();
      allow write: if false; // Cloud Functions only
    }
  }
}
